# ==========================================
# Operion — Configurações de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório!
# ==========================================

# 1. JWT & Segurança da API
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SEGURA_ALEATORIA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# 2. Banco de Dados Local do Backend (FastAPI)
DATABASE_URL=sqlite:///./parametrizacao.db

# 3. Credenciais da Retaguarda (servidor SQL central da rede)
RETAGUARDA_IP=IP_DO_SERVIDOR_RETAGUARDA
RETAGUARDA_DB=NOME_DO_BANCO_RETAGUARDA
RETAGUARDA_USER=usuario_sql_retaguarda
RETAGUARDA_PWD=senha_sql_retaguarda

# 4. Credenciais das Lojas (Servidores e PDVs — ODBC)
LOJAS_UID=SA
LOJAS_PWD=senha_das_lojas

# 5. Credenciais WMI Remoto (Monitor de PCs das Lojas)
# Deixar em branco para usar as credenciais do usuário atual do Windows
# (recomendado em rede de domínio)
LOJAS_WMI_USER=
LOJAS_WMI_PWD=


